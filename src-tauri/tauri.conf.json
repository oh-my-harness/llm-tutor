{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tutor Agent",
  "version": "0.3.5",
  "identifier": "com.gkxtwork.llmtutor",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/dev-desktop.ps1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build --prefix ../web-ui",
    "frontendDist": "../web-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tutor Agent",
        "width": 1200,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
